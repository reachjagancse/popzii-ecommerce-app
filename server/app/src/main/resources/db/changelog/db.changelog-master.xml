<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
         http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="1" author="popzii">
        <createTable tableName="users">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)"/>
            <column name="email" type="VARCHAR(255)">
                <constraints unique="true"/>
            </column>
            <column name="phone" type="VARCHAR(20)">
                <constraints unique="true"/>
            </column>
            <column name="role" type="VARCHAR(50)"/>
            <column name="password" type="VARCHAR(255)"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
    </changeSet>

    <changeSet id="20" author="superapp">
        <createTable tableName="instamart_categories">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)"/>
            <column name="description" type="VARCHAR(1000)"/>
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP"/>
            <column name="deleted_at" type="TIMESTAMP"/>
        </createTable>

        <createTable tableName="instamart_products">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="category_id" type="BIGINT">
                <constraints foreignKeyName="fk_instamart_product_category" referencedTableName="instamart_categories" referencedColumnNames="id"/>
            </column>
            <column name="name" type="VARCHAR(255)"/>
            <column name="description" type="VARCHAR(1000)"/>
            <column name="brand" type="VARCHAR(255)"/>
            <column name="unit" type="VARCHAR(50)"/>
            <column name="base_price" type="DECIMAL(19,2)"/>
            <column name="discount_percent" type="DECIMAL(5,2)"/>
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP"/>
            <column name="deleted_at" type="TIMESTAMP"/>
        </createTable>

        <createTable tableName="instamart_product_variants">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="product_id" type="BIGINT">
                <constraints foreignKeyName="fk_instamart_variant_product" referencedTableName="instamart_products" referencedColumnNames="id"/>
            </column>
            <column name="name" type="VARCHAR(255)"/>
            <column name="sku" type="VARCHAR(100)"/>
            <column name="price" type="DECIMAL(19,2)"/>
            <column name="stock" type="INT"/>
            <column name="is_default" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="bulk_min_qty" type="INT"/>
            <column name="bulk_price" type="DECIMAL(19,2)"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP"/>
            <column name="deleted_at" type="TIMESTAMP"/>
        </createTable>

        <createTable tableName="instamart_inventory_logs">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="product_id" type="BIGINT">
                <constraints foreignKeyName="fk_instamart_log_product" referencedTableName="instamart_products" referencedColumnNames="id"/>
            </column>
            <column name="variant_id" type="BIGINT">
                <constraints foreignKeyName="fk_instamart_log_variant" referencedTableName="instamart_product_variants" referencedColumnNames="id"/>
            </column>
            <column name="change_qty" type="INT"/>
            <column name="reason" type="VARCHAR(255)"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <createIndex tableName="instamart_products" indexName="idx_instamart_products_category">
            <column name="category_id"/>
        </createIndex>
        <createIndex tableName="instamart_product_variants" indexName="idx_instamart_variants_product">
            <column name="product_id"/>
        </createIndex>
        <createIndex tableName="instamart_product_variants" indexName="idx_instamart_variants_sku">
            <column name="sku"/>
        </createIndex>
        <createIndex tableName="instamart_inventory_logs" indexName="idx_instamart_logs_product">
            <column name="product_id"/>
        </createIndex>
        <createIndex tableName="instamart_inventory_logs" indexName="idx_instamart_logs_variant">
            <column name="variant_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="21" author="superapp">
        <createTable tableName="restaurants">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="owner_id" type="BIGINT">
                <constraints foreignKeyName="fk_restaurant_owner" referencedTableName="users" referencedColumnNames="id"/>
            </column>
            <column name="name" type="VARCHAR(255)"/>
            <column name="description" type="VARCHAR(1000)"/>
            <column name="address" type="VARCHAR(500)"/>
            <column name="cuisine" type="VARCHAR(100)"/>
            <column name="rating" type="DECIMAL(3,2)"/>
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP"/>
            <column name="deleted_at" type="TIMESTAMP"/>
        </createTable>

        <createTable tableName="restaurant_menu_categories">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="restaurant_id" type="BIGINT">
                <constraints foreignKeyName="fk_menu_category_restaurant" referencedTableName="restaurants" referencedColumnNames="id"/>
            </column>
            <column name="name" type="VARCHAR(255)"/>
            <column name="sort_order" type="INT"/>
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP"/>
            <column name="deleted_at" type="TIMESTAMP"/>
        </createTable>

        <createTable tableName="restaurant_menu_items">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="category_id" type="BIGINT">
                <constraints foreignKeyName="fk_menu_item_category" referencedTableName="restaurant_menu_categories" referencedColumnNames="id"/>
            </column>
            <column name="name" type="VARCHAR(255)"/>
            <column name="description" type="VARCHAR(1000)"/>
            <column name="price" type="DECIMAL(19,2)"/>
            <column name="is_veg" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="is_available" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP"/>
            <column name="deleted_at" type="TIMESTAMP"/>
        </createTable>

        <createIndex tableName="restaurants" indexName="idx_restaurant_owner">
            <column name="owner_id"/>
        </createIndex>
        <createIndex tableName="restaurants" indexName="idx_restaurant_cuisine">
            <column name="cuisine"/>
        </createIndex>
        <createIndex tableName="restaurant_menu_categories" indexName="idx_menu_category_restaurant">
            <column name="restaurant_id"/>
        </createIndex>
        <createIndex tableName="restaurant_menu_items" indexName="idx_menu_item_category">
            <column name="category_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="22" author="superapp">
        <createTable tableName="carts">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints foreignKeyName="fk_cart_user" referencedTableName="users" referencedColumnNames="id"/>
            </column>
            <column name="status" type="VARCHAR(50)"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>

        <createTable tableName="cart_items">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="cart_id" type="BIGINT">
                <constraints foreignKeyName="fk_cart_item_cart" referencedTableName="carts" referencedColumnNames="id"/>
            </column>
            <column name="product_id" type="BIGINT"/>
            <column name="name" type="VARCHAR(255)"/>
            <column name="price" type="DECIMAL(19,2)"/>
            <column name="quantity" type="INT"/>
        </createTable>

        <createTable tableName="food_orders">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints foreignKeyName="fk_food_order_user" referencedTableName="users" referencedColumnNames="id"/>
            </column>
            <column name="restaurant_id" type="BIGINT">
                <constraints foreignKeyName="fk_food_order_restaurant" referencedTableName="restaurants" referencedColumnNames="id"/>
            </column>
            <column name="total_amount" type="DECIMAL(19,2)"/>
            <column name="status" type="VARCHAR(50)"/>
            <column name="payment_status" type="VARCHAR(50)"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>

        <createTable tableName="food_order_items">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="order_id" type="BIGINT">
                <constraints foreignKeyName="fk_food_order_item_order" referencedTableName="food_orders" referencedColumnNames="id"/>
            </column>
            <column name="menu_item_id" type="BIGINT">
                <constraints foreignKeyName="fk_food_order_item_menu" referencedTableName="restaurant_menu_items" referencedColumnNames="id"/>
            </column>
            <column name="name" type="VARCHAR(255)"/>
            <column name="price" type="DECIMAL(19,2)"/>
            <column name="quantity" type="INT"/>
        </createTable>

        <createIndex tableName="cart_items" indexName="idx_cart_items_cart">
            <column name="cart_id"/>
        </createIndex>
        <createIndex tableName="food_orders" indexName="idx_food_orders_restaurant">
            <column name="restaurant_id"/>
        </createIndex>
        <createIndex tableName="food_order_items" indexName="idx_food_order_items_order">
            <column name="order_id"/>
        </createIndex>
    </changeSet>

